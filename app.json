{
  "expo": {
    "name": "Wears",
    "slug": "wears",
    "scheme": "wears",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "resizeMode": "contain",
          "backgroundColor": "#F5F2EB"
        }
      ],
      "expo-router",
      "expo-font",
      "expo-sharing",
      ["expo-media-library", { "granularPermissions": [] }],
      "expo-apple-authentication",
      "expo-localization",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C4503A",
          "sounds": []
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.727889693667-qj0j4ic4gt385opsr1kbsigehsvdc7no"
        }
      ],
      "./plugins/withMlKitManifestFix.js",
      "./plugins/withRemoveMediaPermissions.js",
      [
        "expo-build-properties",
        {
          "ios": {
            "extraPods": [
              { "name": "GoogleUtilities", "modular_headers": true },
              { "name": "AppCheckCore", "modular_headers": true },
              { "name": "RecaptchaInterop", "modular_headers": true }
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.floresstudios.wears",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Wears accesses your photo library so you can add photos of your clothing items to your closet ledger. For example, choose an existing photo of a pair of shoes or a coat to attach it to that item.",
        "NSPhotoLibraryAddUsageDescription": "Wears saves your shareable cost-per-wear receipts and style cards to your photo library so you can post them to social media or send them to friends.",
        "NSCameraUsageDescription": "Wears uses your camera to take photos of clothing items you add to your closet. For example, snap a photo of a new jacket or dress to log it as an asset in your ledger."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F2EB",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.floresstudios.wears"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "927413a2-3128-468f-9b7e-324c24efd879"
      }
    }
  }
}
